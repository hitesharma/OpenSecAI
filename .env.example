OPENAI_API_KEY=

# Claude Code model and effort for the self-healing node
CLAUDE_MODEL=sonnet
CLAUDE_EFFORT=low

# Environment: "dev" or "prod" (default: prod)
#   dev  → reports/ resolved relative to repo root (desktop/../reports/)
#   prod → reports/ resolved inside platform app-data dir
#          macOS:   ~/Library/Application Support/hitesharma.opensecai/reports/
#          Windows: %APPDATA%\hitesharma.opensecai\reports\
#          Linux:   ~/.local/share/hitesharma.opensecai/reports/
ENV=dev