OPENAI_API_KEY=

# Claude Code model and effort for the self-healing node
CLAUDE_MODEL=haiku
CLAUDE_EFFORT=low

# Environment: "dev" or "prod" (default: prod)
#   dev  → reports/ resolved relative to repo root (desktop/../reports/)
#   prod → reports/ resolved inside platform app-data dir
#          macOS:   ~/Library/Application Support/io.coredge.opensecai/reports/
#          Windows: %APPDATA%\io.coredge.opensecai\reports\
#          Linux:   ~/.local/share/io.coredge.opensecai/reports/
ENV=dev