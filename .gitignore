# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env
*.egg-info/

# Reports — per-run scan artifacts (start.json, end.json, diff.json); generated at runtime
reports/

# direnv — allow file is machine-local
.direnv/

# Misc
*.json
!pyproject.toml
.DS_Store

# Workspaces — cloned target project source trees; checked out locally, never committed
# Layout: workspaces/{project-name}/
workspaces/

# Desktop app (Tauri + React + Vite)
# ────────────────────────────────────────────────────────────────────────────
# npm dependency tree for the React frontend — installed via `npm install`
desktop/node_modules/

# Vite production build output — generated by `npm run build` / `tauri build`
desktop/dist/

# Rust / Cargo compilation cache — can reach several GB for Tauri + WKWebView
desktop/src-tauri/target/

# Tauri-generated code: schema snapshots, mobile bindings, capability JSON schemas
# Regenerated automatically on `tauri dev` / `tauri build`
desktop/src-tauri/gen/

# Un-ignore critical JSON config files that `*.json` above would otherwise suppress
!desktop/package.json
!desktop/tsconfig.json
!desktop/src-tauri/tauri.conf.json
!desktop/src-tauri/capabilities/default.json
!desktop/package-lock.json

# Local sqlite job/run store (ENV=dev)
opensecai.db
opensecai.db-journal
opensecai.db-wal
opensecai.db-shm
